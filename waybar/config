{
  "position": "bottom",
  "modules-left": ["sway/workspaces", "cpu", "memory", "disk"],
  "modules-center": ["clock"],
  "modules-right": ["battery", "network"],

  "sway/workspaces": {
    "format": "{name}",
    "on-click": "activate"
  },

  "cpu": {
    "format": "CPU: {usage}%"
  },

  "memory": {
    "format": "RAM: {used}/{total} GB"
  },

  "disk": {
    "format": "Disk: {free} free"
  },

  "clock": {
    "format": "{:%d-%m-%Y %H:%M:%S}"
  },

  "battery": {
    "format": "BAT: {capacity}%",
    "format-charging": "BAT: {capacity}% ⚡",
    "format-full": "BAT: Full",
    "format-critical": "BAT: {capacity}% !!"
  },

  "network": {
    "format-wifi": "WiFi: {essid} ({signalStrength}%)",
    "format-disconnected": "Offline"
  }
}
